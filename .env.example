# Required InterNetX XML credentials and target host. Credentials are used to
# create an AuthSession at startup; follow-up API calls use the returned
# auth_session hash, which is kept only in memory and never logged raw.
INTERNETX_HOST=https://gateway.autodns.com
INTERNETX_USER=
INTERNETX_PASSWORD=
INTERNETX_CONTEXT=9
TARGET_HOST=subleveldomain.domain.com

# Safe local validation. Keep DRY_RUN=true until you intentionally want live updates.
# DRY_RUN=true: validate config, create and close an InterNetX AuthSession,
# run read-only zone validation, detect public IP, and show what would happen,
# but never perform a live DNS update.
DRY_RUN=true
# RUN_ONCE=true: execute a single check cycle and exit instead of looping.
RUN_ONCE=true
# DEBUG=true: print detailed diagnostic logging without exposing secrets,
# including sanitized XML request/response payloads. Passwords and session
# hashes are redacted.
DEBUG=true

# Optional target parsing override. Use this for zones that cannot be inferred
# from the last two labels of TARGET_HOST, such as example.co.uk.
# TARGET_ZONE=domain.com

# Optional zone lookup selector. Usually not needed; set only if InterNetX asks
# for the first system-managed nameserver when inquiring a zone.
# INTERNETX_SYSTEM_NS=ns.example.com

# Optional authentication diagnostics. In DRY_RUN=true with DEBUG=true, the
# default probe order is auth_only,owner_same, then owner_configured if both
# owner values below are set. AuthSessionCreate stops at the first successful
# variant; DNS mutation remains disabled.
# INTERNETX_AUTH_VARIANTS=auth_only,owner_same
# INTERNETX_OWNER_USER=
# INTERNETX_OWNER_CONTEXT=

# Optional runtime tuning. Defaults are built into the application.
# CHECK_INTERVAL_SECONDS=300
# STATE_DIR=/app/state
# LOG_TARGET=php://stdout
# HTTP_CONNECT_TIMEOUT=10
# HTTP_REQUEST_TIMEOUT=20
# PUBLIC_IPV4_PROVIDERS=https://api.ipify.org,https://ipv4.icanhazip.com,https://ifconfig.me/ip
# ENABLE_IPV6=false
# When IPv6 is disabled, logs say so explicitly. When enabled but unavailable,
# logs report that no IPv6 address was detected.
# PUBLIC_IPV6_PROVIDERS=https://api64.ipify.org,https://ipv6.icanhazip.com

# Optional advanced settings:
# none currently supported. The worker uses the InterNetX XML auth_session flow.
