# Required InterNetX XML credentials and target host. Credentials are used to
# create an AuthSession at startup; follow-up API calls use the returned
# auth_session hash, which is kept only in memory and never logged raw.
INTERNETX_HOST=https://gateway.autodns.com
INTERNETX_USER=
INTERNETX_PASSWORD=
INTERNETX_CONTEXT=9

# Single-target mode: set one full DNS hostname to update.
# TARGET_HOST=dyndns.example.com updates the host label "dyndns" in zone
# "example.com". IPv4 uses the A record; IPv6 uses the AAAA record.
TARGET_HOST=subleveldomain.domain.com

# Multi-target mode: use a comma-separated list of full hostnames that should
# all point to the same detected public IP of this container host.
# Use either TARGET_HOST or TARGET_HOSTS, not both. If both are set, startup
# fails with a clear warning and configuration error.
# TARGET_HOSTS=app1.example.com,app2.example.com,app3.example.com

# Optional explicit per-host zone hints for ambiguous multi-target hostnames
# such as app.example.co.uk or service.example.com.au.
# Format: host=zone,host=zone
# TARGET_HOST_ZONES=app.example.co.uk=example.co.uk,service.example.com.au=example.com.au

# Optional Pushover notifications. All three values are required to enable it.
# Notifications are sent only when the detected public IP actually changed.
# DRY_RUN=true suppresses notification delivery.
# Message format starts with the configured location prefix, for example Berlin.
# Legacy PUSHOVER_LOCATION_NAME is accepted temporarily as a deprecated fallback.
# PUSHOVER_APP_KEY=
# PUSHOVER_USER_KEY=
# PUSHOVER_LOCATION_PREFIX=

# Create the relevant record(s) in the DNS zone before live updates.
# TTL is not configured by this worker; set it on the DNS record in InterNetX.
# A TTL around 300 seconds is a common starting point for DynDNS-style records.

# Core public IP detection. At least one address family must be enabled.
# Enable IPv4 for normal dual-stack/IPv4 networks. Disable it for IPv6-only
# connections where IPv4 detection providers are expected to fail.
ENABLE_IPV4=true
PUBLIC_IPV4_PROVIDERS=https://api.ipify.org,https://ipv4.icanhazip.com,https://ifconfig.me/ip

# IPv6 is disabled by default. Enable it for IPv6 or dual-stack updates.
ENABLE_IPV6=false
PUBLIC_IPV6_PROVIDERS=https://api64.ipify.org,https://ipv6.icanhazip.com

# Safe local validation. Keep DRY_RUN=true until you intentionally want live updates.
# DRY_RUN=true: validate config, create and close an InterNetX AuthSession,
# run read-only zone validation, detect public IP, and show what would happen,
# but never perform a live DNS update.
DRY_RUN=true
# FORCE_UPDATE_ON_NO_CHANGE=false: default behavior skips unnecessary live DNS
# update requests when the detected public IP is unchanged and all targets are
# already in sync. Set true only if you intentionally want live update requests
# even in that no-change case.
# FORCE_UPDATE_ON_NO_CHANGE=false
# RUN_ONCE=true: execute a single check cycle and exit instead of looping.
# Use docker compose run --rm dynamic-dns-worker for one-shot validation.
# Use RUN_ONCE=false with docker compose up -d for continuous mode.
RUN_ONCE=true
# DEBUG=true: print detailed diagnostic logging without exposing secrets,
# including sanitized XML request/response payloads. Passwords and session
# hashes are redacted.
DEBUG=true

# Terminal logs use colorized severity markers on stdout/stderr by default.
# Set NO_COLOR=1 in the runtime environment to disable ANSI colors.

# Optional single-target parsing override. Use this only with TARGET_HOST for
# zones that cannot be inferred from the last two labels, such as example.co.uk.
# For multi-target mode, use TARGET_HOST_ZONES for explicit per-host zone hints.
# TARGET_ZONE=domain.com

# Optional zone lookup selector. Usually not needed; set only if InterNetX asks
# for the first system-managed nameserver when inquiring a zone. This maps to
# the XML Zone object field <system_ns>; normal DynDNS runs usually leave it unset.
# INTERNETX_SYSTEM_NS=ns.example.com

# Optional runtime tuning. Defaults are built into the application.
# CHECK_INTERVAL_SECONDS=300
# STATE_DIR=/app/state
# Default logs go to container stdout/stderr via php://stdout.
# LOG_TARGET=php://stdout
# Runtime timestamps use TZ when set.
# TZ=Europe/Zurich
# Optional JSONL history of detected IP status after each successful cycle.
# IP_STATUS_LOG=/app/state/ip-status.log
# Docker healthcheck status file. The default is STATE_DIR/health.json.
# HEALTH_STATUS_FILE=/app/state/health.json
# HEALTH_MAX_AGE_SECONDS defaults to roughly three check intervals plus one minute.
# HEALTH_MAX_AGE_SECONDS=960
# HTTP_CONNECT_TIMEOUT=10
# HTTP_REQUEST_TIMEOUT=20

# Optional advanced settings:
# none currently supported. The worker uses the InterNetX XML auth_session flow.
