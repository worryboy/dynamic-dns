# DNS-only environment for docker-compose.traefik-crowdsec-example.yml.
# Keep this separate from the Traefik/CrowdSec stack .env to avoid variable
# collisions with reverse-proxy, CrowdSec, certificate, and dashboard settings.

INTERNETX_HOST=https://gateway.autodns.com
INTERNETX_USER=
INTERNETX_PASSWORD=
INTERNETX_CONTEXT=9

# Multi-target DNS names that should all resolve to this host's public IP.
TARGET_HOSTS=app1.example.com,app2.example.com,traefik.example.com

# Optional explicit per-host zone hints for ambiguous multi-target hostnames.
# TARGET_HOST_ZONES=app.example.co.uk=example.co.uk,service.example.com.au=example.com.au

ENABLE_IPV4=true
ENABLE_IPV6=false

# Run once with DRY_RUN=true before switching to continuous live updates.
# Use docker compose run --rm internetx-dyndns for RUN_ONCE=true validation.
# Use RUN_ONCE=false with docker compose up -d for continuous mode.
DRY_RUN=true
FORCE_UPDATE_ON_NO_CHANGE=false
RUN_ONCE=true
DEBUG=true

# Optional Pushover notifications for real public IP changes.
# DRY_RUN=true suppresses notification delivery.
# PUSHOVER_APP_KEY=
# PUSHOVER_USER_KEY=
PUSHOVER_LOCATION_PREFIX=Berlin

# Optional runtime tuning.
# CHECK_INTERVAL_SECONDS=300
# LOG_TARGET=php://stdout
# TZ=Europe/Zurich
# IP_STATUS_LOG=/app/state/ip-status.log
# HEALTH_STATUS_FILE=/app/state/health.json
# HEALTH_MAX_AGE_SECONDS=960
# HTTP_CONNECT_TIMEOUT=10
# HTTP_REQUEST_TIMEOUT=20
